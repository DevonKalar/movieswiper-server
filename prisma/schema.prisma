generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum Reaction {
  like
  reject
}

enum EmailStatus {
  pending
  sending
  sent
  failed
}

enum EmailEventType {
  welcome
  watchlist_milestone
  weekly_digest
  password_reset
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  firstName          String               @map("first_name")
  lastName           String               @map("last_name")
  password           String
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  watchlistItems     Watchlist[]
  refreshTokens      RefreshToken[]
  movieReactions     MovieReaction[]
  movieViews         MovieView[]
  emailNotifications EmailNotification[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Movies {
  id            Int         @id // TMDB movie ID
  title         String
  description   String
  releaseDate   DateTime    @map("release_date")
  posterUrl     String?     @map("poster_url")
  genres        String[]
  ratings       Float
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  watchlistedBy  Watchlist[]
  movieReactions MovieReaction[]
  movieViews     MovieView[]

  @@map("movies")
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  movieId   Int      @map("movie_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movies @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("watchlists")
}

model MovieReaction {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  movieId   Int      @map("movie_id")
  reaction  Reaction
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movies @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("movie_reactions")
}

model MovieView {
  id       Int      @id @default(autoincrement())
  userId   String   @map("user_id")
  movieId  Int      @map("movie_id")
  viewedAt DateTime @default(now()) @map("viewed_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movies @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("movie_views")
}

model EmailNotification {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  eventType      EmailEventType @map("event_type")
  status         EmailStatus    @default(pending)
  idempotencyKey String         @unique @map("idempotency_key")
  templateData   Json           @map("template_data")
  resendId       String?        @map("resend_id")
  lastError      String?        @map("last_error")
  attemptCount   Int            @default(0) @map("attempt_count")
  sentAt         DateTime?      @map("sent_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("email_notifications")
}
